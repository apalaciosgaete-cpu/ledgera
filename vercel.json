{
  "buildCommand": "next build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "regions": ["fra1"],
  "env": {
    "NEXT_TURBOPACK": "0"
  },
  "crons": [
    {
      "path": "/api/cron/fx-rate",
      "schedule": "0 14 * * *"
    }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
