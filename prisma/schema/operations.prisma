// ── Staging physical models ────────────────────────────────────────────────────

model StagingEvent {
  id               String   @id @default(cuid())
  userId           String
  source           String
  provider         String
  status           String   @default("PENDING")
  normalizedType   String
  title            String
  subtitle         String?
  amountLabel      String?
  occurredAt       DateTime
  linkedMovementId String?
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sources   StagingEventSource[]
  decisions StagingDecision[]

  @@index([userId])
  @@index([status])
  @@index([source])
  @@index([occurredAt])
  @@map("staging_events")
}

model StagingEventSource {
  id             String  @id @default(cuid())
  stagingEventId String
  provider       String
  recordId       String
  rawType        String?
  metadata       String?

  stagingEvent StagingEvent @relation(fields: [stagingEventId], references: [id])

  @@index([stagingEventId])
  @@index([recordId])
  @@map("staging_event_sources")
}

model StagingDecision {
  id             String   @id @default(cuid())
  userId         String
  stagingEventId String?
  action         String
  actorId        String?
  actorEmail     String?
  beforeStatus   String?
  afterStatus    String?
  decisionHash   String
  validationCode String?  @unique
  metadata       String?
  createdAt      DateTime @default(now())

  stagingEvent StagingEvent? @relation(fields: [stagingEventId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([decisionHash])
  @@index([createdAt])
  @@map("staging_decisions")
}

// ── Audit chain models ─────────────────────────────────────────────────────────

model IntegrityChainEntry {
  id           String   @id @default(cuid())
  userId       String
  entityType   String
  entityId     String
  action       String
  sequence     Int
  previousHash String?
  currentHash String
  payloadHash  String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([currentHash])
  @@map("integrity_chain_entries")
}

model LogicalRollback {
  id              String   @id @default(cuid())
  userId          String
  entityType      String
  entityId        String
  rollbackReason  String
  rollbackPayload String
  actorId         String?
  actorEmail      String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@map("logical_rollbacks")
}

// ── Wallets / on-chain ─────────────────────────────────────────────────────────

model WalletConnection {
  id         String    @id @default(cuid())
  userId     String
  network    String
  address    String
  label      String?
  status     String    @default("ACTIVE")
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  transactions OnchainTransaction[]

  @@unique([userId, network, address])
  @@index([userId])
  @@map("wallet_connections")
}

model OnchainTransaction {
  id             String    @id @default(cuid())
  userId         String
  walletId       String
  txHash         String
  network        String
  blockNumber    Int?
  blockTimestamp DateTime?
  from           String?
  to             String?
  value          String?
  gasUsed        String?
  status         String    @default("PENDING")
  rawPayload     String?
  createdAt      DateTime  @default(now())

  wallet        WalletConnection      @relation(fields: [walletId], references: [id])
  decodedEvents OnchainDecodedEvent[]

  @@unique([network, txHash])
  @@index([userId])
  @@index([walletId])
  @@index([blockTimestamp])
  @@map("onchain_transactions")
}

model OnchainDecodedEvent {
  id           String   @id @default(cuid())
  txId         String
  userId       String
  eventType    String
  contractAddr String?
  tokenSymbol  String?
  tokenAmount  String?
  fromAddr     String?
  toAddr       String?
  usdValue     Float?
  taxTreatment String?
  metadata     String?
  createdAt    DateTime @default(now())

  transaction OnchainTransaction @relation(fields: [txId], references: [id])

  @@index([txId])
  @@index([userId])
  @@index([eventType])
  @@map("onchain_decoded_events")
}

// ── Chat interno ──────────────────────────────────────────────────────────────

model ChatConversation {
  id         String        @id @default(cuid())
  userId     String?
  sessionId  String        @unique
  status     String        @default("OPEN")
  guestName  String?
  guestEmail String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]
  user       users?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  sender         String
  content        String
  createdAt      DateTime         @default(now())
  readAt         DateTime?
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

model ChatPushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("chat_push_subscriptions")
}
