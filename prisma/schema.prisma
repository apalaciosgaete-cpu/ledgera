generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PortfolioMovement {
  id                      String   @id @default(cuid())
  userId                  String
  type                    String
  symbol                  String
  quantity                Float
  priceUsd                Float
  feeUsd                  Float    @default(0)
  executedAt              DateTime
  exchange                String?
  notes                   String?
  suggestedTaxCategory    String   @default("UNCLASSIFIED")
  appliedTaxCategory      String?
  taxClassificationSource String   @default("SYSTEM")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([symbol])
  @@index([executedAt])
  @@map("portfolio_movements")
}

model TaxEvent {
  id                   String   @id @default(cuid())
  userId               String
  movementId           String   @unique
  eventType            String
  symbol               String
  executedAt           DateTime
  quantity             Float
  effectiveTaxCategory String
  averageCostUsdAtSale Float?
  proceedsGrossUsd     Float?
  proceedsNetUsd       Float?
  costBasisUsd         Float?
  feeUsd               Float?
  realizedPnlUsd       Float?
  usdClp               Float?
  proceedsGrossClp     Float?
  proceedsNetClp       Float?
  costBasisClp         Float?
  feeClp               Float?
  realizedPnlClp       Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([movementId])
  @@index([executedAt])
  @@index([symbol])
  @@map("tax_events")
}

model TaxPeriodClose {
  id           String    @id @default(cuid())
  userId       String
  year         Int
  status       String    @default("OPEN")
  closedAt     DateTime?
  closedReason String?
  reopenedAt   DateTime?
  reopenReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user users @relation(fields: [userId], references: [id])

  @@unique([userId, year])
  @@index([userId])
  @@index([year])
  @@map("tax_period_closures")
}

model TaxPeriodAuditLog {
  id         String   @id @default(cuid())
  userId     String
  year       Int
  action     String
  reason     String?
  actorId    String?
  actorEmail String?
  metadata   String?
  createdAt  DateTime @default(now())

  user users @relation(fields: [userId], references: [id])

  @@index([year])
  @@index([action])
  @@index([userId, year])
  @@map("tax_period_audit_logs")
}

model TaxPeriodSnapshot {
  id              String   @id @default(cuid())
  userId          String   @default("")
  year            Int
  contentHash     String
  snapshotPayload String
  createdAt       DateTime @default(now())

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([year])
  @@index([contentHash])
  @@index([userId, year])
  @@map("tax_period_snapshots")
}

model TaxDeclaration {
  id              String    @id @default(cuid())
  userId          String
  taxYear         Int
  declarationType String
  status          String    @default("DRAFT")
  source          String    @default("SYSTEM")
  payloadJson     String
  contentHash     String
  generatedAt     DateTime  @default(now())
  confirmedAt     DateTime?
  voidedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      users                    @relation(fields: [userId], references: [id])
  auditLogs TaxDeclarationAuditLog[]

  @@index([userId])
  @@index([taxYear])
  @@index([declarationType])
  @@index([status])
  @@index([contentHash])
  @@index([userId, taxYear])
  @@map("tax_declarations")
}

model TaxDeclarationAuditLog {
  id              String   @id @default(cuid())
  userId          String
  declarationId   String
  action          String
  actorId         String?
  actorEmail      String?
  taxYear         Int
  declarationType String
  statusFrom      String?
  statusTo        String?
  contentHash     String?
  ipAddress       String?
  userAgent       String?
  metadata        String?
  createdAt       DateTime @default(now())

  user        users          @relation(fields: [userId], references: [id])
  declaration TaxDeclaration @relation(fields: [declarationId], references: [id])

  @@index([userId])
  @@index([declarationId])
  @@index([action])
  @@index([taxYear])
  @@index([createdAt])
  @@index([userId, taxYear])
  @@map("tax_declaration_audit_logs")
}

model FxRate {
  id        String   @id @default(cuid())
  currency  String
  date      DateTime
  valueClp  Float
  source    String   @default("mindicador")
  createdAt DateTime @default(now())

  @@unique([currency, date], name: "currency_date")
  @@map("fx_rates")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("system_settings")
}

model SettingsAuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  action    String
  key       String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("settings_audit_logs")
}

model AdminAuditLog {
  id              String   @id @default(cuid())
  action          String
  actorId         String?
  actorEmail      String?
  targetUserId    String?
  targetUserEmail String?
  ipAddress       String?
  userAgent       String?
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model users {
  id                      String    @id @default(cuid())
  email                   String    @unique
  full_name               String
  password_hash           String
  status                  String    @default("active")
  email_verified_at       DateTime? @db.Timestamptz(6)
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime  @default(now()) @db.Timestamptz(6)
  role                    String    @default("personal")
  subscription_plan       String    @default("BASICO")
  subscription_expires_at DateTime? @db.Timestamptz(6)
  twoFactorSecret         String?
  twoFactorEnabled        Boolean   @default(false)

  portfolios              portfolios[]
  sessions                sessions[]
  portfolioMovements      PortfolioMovement[]
  taxEvents               TaxEvent[]
  taxPeriodClosures       TaxPeriodClose[]
  taxPeriodAuditLogs      TaxPeriodAuditLog[]
  taxPeriodSnapshots      TaxPeriodSnapshot[]
  taxDeclarations         TaxDeclaration[]
  taxDeclarationAuditLogs TaxDeclarationAuditLog[]

  @@index([email], map: "idx_users_email")
  @@index([subscription_expires_at], map: "idx_users_subscription_expires_at")
}

model portfolios {
  id         String   @id @default(cuid())
  user_id    String
  name       String   @default("Main Portfolio")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_portfolios_user_id")
  @@map("portfolios")
}

model sessions {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  created_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at DateTime @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_sessions_user_id")
  @@index([token], map: "idx_sessions_token")
  @@map("sessions")
}
