generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PortfolioMovement {
  id                      String    @id @default(cuid())
  userId                  String    @default("")
  type                    String
  symbol                  String
  quantity                Float
  priceUsd                Float
  feeUsd                  Float     @default(0)
  suggestedTaxCategory    String    @default("UNCLASSIFIED")
  appliedTaxCategory      String?
  taxClassificationSource String    @default("SYSTEM")
  executedAt              DateTime  @default(now())
  deletedAt               DateTime?
  deletedReason           String?
  source                  String    @default("MANUAL")
  externalId              String?

  user             users                  @relation(fields: [userId], references: [id])
  taxEvent         TaxEvent?
  importRecord     ExchangeImportRecord?
  taxLedgerEntries TaxLedgerEntry[]

  @@index([userId])
  @@index([executedAt])
  @@index([userId, executedAt])
  @@index([source])
  @@index([type])
  @@index([symbol])
  @@index([userId, type])
  @@index([userId, symbol])
  @@map("portfolio_movements")
}

model TaxEvent {
  id                   String   @id @default(cuid())
  userId               String   @default("")
  movementId           String   @unique
  symbol               String
  eventType            String
  quantity             Float
  effectiveTaxCategory String   @default("UNCLASSIFIED")
  averageCostUsdAtSale Float    @default(0)
  proceedsGrossUsd     Float    @default(0)
  proceedsNetUsd       Float    @default(0)
  costBasisUsd         Float    @default(0)
  feeUsd               Float    @default(0)
  realizedPnlUsd       Float    @default(0)
  usdClp               Float
  proceedsGrossClp     Float    @default(0)
  proceedsNetClp       Float    @default(0)
  costBasisClp         Float    @default(0)
  feeClp               Float    @default(0)
  realizedPnlClp       Float    @default(0)
  executedAt           DateTime
  taxYear              Int      @default(0)

  user             users             @relation(fields: [userId], references: [id])
  movement         PortfolioMovement @relation(fields: [movementId], references: [id])
  taxLedgerEntries TaxLedgerEntry[]

  @@index([userId])
  @@index([taxYear])
  @@index([symbol])
  @@index([userId, taxYear])
  @@index([userId, executedAt])
  @@map("tax_events")
}

model TaxLedgerEntry {
  id                String   @id @default(cuid())
  userId            String

  movementId        String?
  taxEventId        String?

  taxYear           Int
  taxMonth          Int

  ledgerType        String
  ledgerCategory    String

  assetSymbol       String
  quantity          Float

  proceedsClp       Float    @default(0)
  costBasisClp      Float    @default(0)
  realizedGainClp   Float    @default(0)

  taxTreatment      String
  siiClassification String

  source            String   @default("SYSTEM")
  createdAt         DateTime @default(now())

  user      users              @relation(fields: [userId], references: [id])
  taxEvent  TaxEvent?          @relation(fields: [taxEventId], references: [id])
  movement  PortfolioMovement? @relation(fields: [movementId], references: [id])

  @@index([userId, taxYear])
  @@index([taxTreatment])
  @@index([siiClassification])
  @@map("tax_ledger_entries")
}

model AnnualTaxSummary {
  id                    String   @id @default(cuid())
  userId                String
  taxYear               Int

  grossProceedsClp      Float    @default(0)
  costBasisClp          Float    @default(0)
  realizedGainClp       Float    @default(0)
  realizedLossClp       Float    @default(0)
  netTaxableGainClp     Float    @default(0)

  reviewCount           Int      @default(0)
  taxableEventCount     Int      @default(0)

  preliminaryTaxBaseClp Float    @default(0)
  source                String   @default("SYSTEM")

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user users @relation(fields: [userId], references: [id])

  @@unique([userId, taxYear])
  @@index([taxYear])
  @@map("annual_tax_summaries")
}

model ReportValidation {
  id        String    @id @default(cuid())
  userId    String    @default("")
  type      String    @default("INFORMATIVE")
  year      Int       @default(0)
  hash      String    @unique @default("")
  symbol    String?
  issuedAt  DateTime  @default(now())
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("report_validations")
}

model TaxPeriodClose {
  id           String    @id @default(cuid())
  userId       String    @default("")
  periodYear   Int
  status       String    @default("CLOSED")
  closedReason String?
  closedAt     DateTime  @default(now())
  reopenedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user users @relation(fields: [userId], references: [id])

  @@unique([userId, periodYear])
  @@map("tax_period_closures")
}

model TaxPeriodAuditLog {
  id         String   @id @default(cuid())
  userId     String   @default("")
  year       Int
  action     String
  reason     String?
  actorId    String?
  actorEmail String?
  metadata   String?
  createdAt  DateTime @default(now())

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([year])
  @@index([action])
  @@index([userId, year])
  @@map("tax_period_audit_logs")
}

model TaxPeriodSnapshot {
  id              String   @id @default(cuid())
  userId          String   @default("")
  year            Int
  contentHash     String
  snapshotPayload String
  createdAt       DateTime @default(now())

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([year])
  @@index([contentHash])
  @@index([userId, year])
  @@map("tax_period_snapshots")
}

model TaxDeclaration {
  id              String    @id @default(cuid())
  userId          String
  taxYear         Int
  declarationType String
  status          String    @default("DRAFT")
  source          String    @default("SYSTEM")
  payloadJson     String
  contentHash     String
  generatedAt     DateTime  @default(now())
  confirmedAt     DateTime?
  voidedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      users                    @relation(fields: [userId], references: [id])
  auditLogs TaxDeclarationAuditLog[]

  @@index([userId])
  @@index([taxYear])
  @@index([declarationType])
  @@index([status])
  @@index([contentHash])
  @@index([userId, taxYear])
  @@map("tax_declarations")
}

model TaxDeclarationAuditLog {
  id              String   @id @default(cuid())
  userId          String
  declarationId   String
  action          String
  actorId         String?
  actorEmail      String?
  taxYear         Int
  declarationType String
  statusFrom      String?
  statusTo        String?
  contentHash     String?
  beforeState     String?
  afterState      String?
  previousHash    String?
  currentHash     String?
  ipAddress       String?
  userAgent       String?
  metadata        String?
  createdAt       DateTime @default(now())

  user        users          @relation(fields: [userId], references: [id])
  declaration TaxDeclaration @relation(fields: [declarationId], references: [id])

  @@index([userId])
  @@index([declarationId])
  @@index([action])
  @@index([taxYear])
  @@index([createdAt])
  @@index([userId, taxYear])
  @@map("tax_declaration_audit_logs")
}

model TaxClassificationAuditLog {
  id              String   @id @default(cuid())
  userId          String
  movementId      String
  action          String
  actorId         String?
  actorEmail      String?
  beforeState     String?
  afterState      String?
  previousHash    String?
  currentHash     String?
  ipAddress       String?
  userAgent       String?
  metadata        String?
  createdAt       DateTime @default(now())

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([movementId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("tax_classification_audit_logs")
}

model TaxEventAuditLog {
  id              String   @id @default(cuid())
  userId          String
  taxEventId      String
  action          String
  actorId         String?
  actorEmail      String?
  taxYear         Int
  beforeState     String?
  afterState      String?
  previousHash    String?
  currentHash     String?
  ipAddress       String?
  userAgent       String?
  metadata        String?
  createdAt       DateTime @default(now())

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([taxEventId])
  @@index([action])
  @@index([taxYear])
  @@index([createdAt])
  @@index([userId, taxYear])
  @@map("tax_event_audit_logs")
}

model MovementAuditLog {
  id              String   @id @default(cuid())
  userId          String
  movementId      String
  action          String
  actorId         String?
  actorEmail      String?
  beforeState     String?
  afterState      String?
  previousHash    String?
  currentHash     String?
  ipAddress       String?
  userAgent       String?
  metadata        String?
  createdAt       DateTime @default(now())

  user users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([movementId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("movement_audit_logs")
}

model FxRate {
  id        String   @id @default(cuid())
  currency  String
  date      DateTime
  valueClp  Float
  source    String   @default("mindicador")
  createdAt DateTime @default(now())

  @@unique([currency, date], name: "currency_date")
  @@map("fx_rates")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("system_settings")
}

model SettingsAuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  action    String
  key       String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("settings_audit_logs")
}

model AdminAuditLog {
  id              String   @id @default(cuid())
  action          String
  actorId         String?
  actorEmail      String?
  targetUserId    String?
  targetUserEmail String?
  ipAddress       String?
  userAgent       String?
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model BillingCustomer {
  id                 String   @id @default(cuid())
  userId             String
  provider           String
  providerCustomerId String?
  email              String
  fullName           String?
  metadata           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user          users                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions BillingSubscription[]
  payments      BillingPayment[]

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
  @@index([providerCustomerId])
  @@map("billing_customers")
}

model BillingSubscription {
  id                     String    @id @default(cuid())
  userId                 String
  customerId             String?
  provider               String
  providerSubscriptionId String?
  plan                   String
  status                 String    @default("PENDING")
  currency               String    @default("CLP")
  amount                 Int
  interval               String    @default("MONTHLY")
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  metadata               String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user     users            @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer BillingCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  payments BillingPayment[]

  @@index([userId])
  @@index([customerId])
  @@index([provider])
  @@index([providerSubscriptionId])
  @@index([status])
  @@index([plan])
  @@map("billing_subscriptions")
}

model BillingPayment {
  id                String    @id @default(cuid())
  userId            String
  customerId        String?
  subscriptionId    String?
  provider          String
  providerPaymentId String?
  checkoutId        String?
  status            String    @default("PENDING")
  amount            Int
  currency          String    @default("CLP")
  description       String
  paymentUrl        String?
  paidAt            DateTime?
  failedAt          DateTime?
  metadata          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user         users                @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer     BillingCustomer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  subscription BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([customerId])
  @@index([subscriptionId])
  @@index([provider])
  @@index([providerPaymentId])
  @@index([checkoutId])
  @@index([status])
  @@map("billing_payments")
}

model BillingWebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  providerEventId String?
  eventType       String
  status          String    @default("RECEIVED")
  payload         String
  processedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([provider])
  @@index([providerEventId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@map("billing_webhook_events")
}

model users {
  id                      String    @id @default(cuid())
  email                   String    @unique
  full_name               String
  password_hash           String
  status                  String    @default("active")
  email_verified_at       DateTime? @db.Timestamptz(6)
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime  @default(now()) @db.Timestamptz(6)
  role                    String    @default("personal")
  subscription_plan       String    @default("BASICO")
  subscription_expires_at DateTime? @db.Timestamptz(6)
  twoFactorSecret         String?
  twoFactorEnabled        Boolean   @default(false)

  // CAPA 4.1 — Activación: preparado para migración futura
  onboardingCompleted     Boolean   @default(false)
  activatedAt             DateTime? @db.Timestamptz(6)
  activationSource        String?

  rut                     String?
  phone                   String?
  address                 String?
  commune                 String?
  country                 String?   @default("Chile")

  portfolios              portfolios[]
  sessions                sessions[]
  authAccounts            Account[]
  authSessions            Session[]
  portfolioMovements      PortfolioMovement[]
  taxEvents               TaxEvent[]
  taxPeriodClosures       TaxPeriodClose[]
  taxPeriodAuditLogs      TaxPeriodAuditLog[]
  taxPeriodSnapshots      TaxPeriodSnapshot[]
  taxDeclarations         TaxDeclaration[]
  taxDeclarationAuditLogs TaxDeclarationAuditLog[]
  billingCustomers        BillingCustomer[]
  billingSubscriptions    BillingSubscription[]
  billingPayments         BillingPayment[]
  exchangeConnections     ExchangeConnection[]
  exchangeImportRecords   ExchangeImportRecord[]
  taxLedgerEntries        TaxLedgerEntry[]
  annualTaxSummaries      AnnualTaxSummary[]
  exchangeSyncPeriods     ExchangeSyncPeriod[]
  bankMovements           BankMovement[]
  bankFileUploads         BankFileUpload[]
  bankCsvTemplates        BankCsvTemplate[]
  chatConversations       ChatConversation[]
  taxClassificationAuditLogs TaxClassificationAuditLog[]
  taxEventAuditLogs       TaxEventAuditLog[]
  movementAuditLogs       MovementAuditLog[]
  taxProfile              TaxProfile?
  taxDocuments            TaxDocument[]
  alerts                  Alert[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model Alert {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  category       String
  severity       String
  title          String
  message        String
  status         String   @default("OPEN")
  metadata       Json?
  source         String?
  acknowledgedAt DateTime? @map("acknowledged_at")
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@map("alerts")
}

model portfolios {
  id         String   @id @default(cuid())
  user_id    String
  name       String   @default("Main Portfolio")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_portfolios_user_id")
  @@map("portfolios")
}

model sessions {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  created_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at DateTime @db.Timestamptz(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_sessions_user_id")
  @@index([token], map: "idx_sessions_token")
  @@map("sessions")
}

model ExchangeConnection {
  id                 String    @id @default(cuid())
  userId             String
  exchange           String
  apiKeyEncrypted    String
  apiSecretEncrypted String
  status             String
  permissions        String
  lastSyncAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user        users                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  imports     ExchangeImportRecord[]
  syncPeriods ExchangeSyncPeriod[]

  @@unique([userId, exchange])
  @@index([userId])
  @@map("exchange_connections")
}

model ExchangeImportRecord {
  id             String    @id @default(cuid())
  userId         String
  connectionId   String
  provider       String
  externalId     String
  externalType   String
  rawPayload          String
  normalizedJson      String?
  normalizedEventType String?
  taxTreatment        String?
  inventoryEffect     String?
  economicEffect      String?
  status              String    @default("PENDING")
  movementId          String?   @unique
  occurredAt          DateTime
  createdAt           DateTime  @default(now())

  user       users               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection ExchangeConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  movement   PortfolioMovement?  @relation(fields: [movementId], references: [id])

  @@unique([userId, provider, externalId])
  @@index([userId])
  @@index([connectionId])
  @@index([status])
  @@index([provider])
  @@index([normalizedEventType])
  @@map("exchange_import_records")
}

model ExchangeSyncPeriod {
  id            String    @id @default(cuid())
  userId        String
  connectionId  String
  provider      String

  year          Int
  month         Int

  status        String    @default("PENDING")

  importedCount Int       @default(0)
  errorCount    Int       @default(0)

  startedAt     DateTime?
  finishedAt    DateTime?
  lastError     String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       users              @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection ExchangeConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, year, month])
  @@index([userId, year])
  @@index([userId, provider, status])
  @@map("exchange_sync_periods")
}

model BankFileUpload {
  id           String   @id @default(cuid())
  userId       String
  bankName     String?
  fileName     String
  fileType     String
  fileHash     String
  status       String   @default("IMPORTED")
  totalRows    Int      @default(0)
  importedRows Int      @default(0)
  errorRows    Int      @default(0)
  rawJson      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      users          @relation(fields: [userId], references: [id])
  movements BankMovement[]

  @@index([userId, createdAt])
  @@unique([userId, fileHash])
  @@map("bank_file_uploads")
}

model BankMovement {
  id          String   @id @default(cuid())
  userId      String
  uploadId    String?
  source      String   @default("BANK_FILE")
  bankName    String?
  externalId  String?
  occurredAt  DateTime
  description String
  amountClp   Float
  direction   String
  balanceClp  Float?
  status      String   @default("IMPORTED")
  rawJson     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bankCategory   String?
  categoryReason String?

  matchedPortfolioMovementId String?
  matchedConfidence          Float?
  matchedAt                  DateTime?
  matchedReason              String?

  user   users           @relation(fields: [userId], references: [id])
  upload BankFileUpload? @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([userId, direction])
  @@index([userId, status])
  @@index([userId, bankName])
  @@index([userId, matchedPortfolioMovementId])
  @@unique([userId, externalId])
  @@map("bank_movements")
}

model BankReconciliationAuditLog {
  id                  String   @id @default(cuid())
  userId              String
  action              String
  bankMovementId      String
  portfolioMovementId String?
  confidence          Float?
  reason              String?
  metadata            String?
  createdAt           DateTime @default(now())

  @@index([userId, createdAt])
  @@index([bankMovementId])
  @@index([portfolioMovementId])
  @@map("bank_reconciliation_audit_logs")
}

model BankReconciliationReportValidation {
  id             String   @id @default(cuid())
  userId         String
  validationCode String   @unique
  contentHash    String
  reportType     String   @default("BANK_RECONCILIATION")
  metadata       String?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@map("bank_reconciliation_report_validations")
}

model BankCsvTemplate {
  id         String   @id @default(cuid())
  userId     String
  bankName   String
  colDate    String
  colDesc    String
  colAmount  String?
  colDebit   String?
  colCredit  String?
  colBalance String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user users @relation(fields: [userId], references: [id])

  @@unique([userId, bankName])
  @@map("bank_csv_templates")
}

// ── Staging physical models ────────────────────────────────────────────────────

model StagingEvent {
  id               String   @id @default(cuid())
  userId           String
  source           String
  provider         String
  status           String   @default("PENDING")
  normalizedType   String
  title            String
  subtitle         String?
  amountLabel      String?
  occurredAt       DateTime
  linkedMovementId String?
  metadata         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sources   StagingEventSource[]
  decisions StagingDecision[]

  @@index([userId])
  @@index([status])
  @@index([source])
  @@index([occurredAt])
  @@map("staging_events")
}

model StagingEventSource {
  id             String @id @default(cuid())
  stagingEventId String
  provider       String
  recordId       String
  rawType        String?
  metadata       String?

  stagingEvent StagingEvent @relation(fields: [stagingEventId], references: [id])

  @@index([stagingEventId])
  @@index([recordId])
  @@map("staging_event_sources")
}

model StagingDecision {
  id             String   @id @default(cuid())
  userId         String
  stagingEventId String?
  action         String
  actorId        String?
  actorEmail     String?
  beforeStatus   String?
  afterStatus    String?
  decisionHash   String
  validationCode String?  @unique
  metadata       String?
  createdAt      DateTime @default(now())

  stagingEvent StagingEvent? @relation(fields: [stagingEventId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([decisionHash])
  @@index([createdAt])
  @@map("staging_decisions")
}

// ── Audit chain models ─────────────────────────────────────────────────────────

model IntegrityChainEntry {
  id           String   @id @default(cuid())
  userId       String
  entityType   String
  entityId     String
  action       String
  sequence     Int
  previousHash String?
  currentHash  String
  payloadHash  String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([currentHash])
  @@map("integrity_chain_entries")
}

model LogicalRollback {
  id              String   @id @default(cuid())
  userId          String
  entityType      String
  entityId        String
  rollbackReason  String
  rollbackPayload String
  actorId         String?
  actorEmail      String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@map("logical_rollbacks")
}

// ── Wallets / on-chain ─────────────────────────────────────────────────────────

model WalletConnection {
  id          String   @id @default(cuid())
  userId      String
  network     String
  address     String
  label       String?
  status      String   @default("ACTIVE")
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions OnchainTransaction[]

  @@unique([userId, network, address])
  @@index([userId])
  @@map("wallet_connections")
}

model OnchainTransaction {
  id               String   @id @default(cuid())
  userId           String
  walletId         String
  txHash           String
  network          String
  blockNumber      Int?
  blockTimestamp   DateTime?
  from             String?
  to               String?
  value            String?
  gasUsed          String?
  status           String   @default("PENDING")
  rawPayload       String?
  createdAt        DateTime @default(now())

  wallet       WalletConnection    @relation(fields: [walletId], references: [id])
  decodedEvents OnchainDecodedEvent[]

  @@unique([network, txHash])
  @@index([userId])
  @@index([walletId])
  @@index([blockTimestamp])
  @@map("onchain_transactions")
}

model OnchainDecodedEvent {
  id            String   @id @default(cuid())
  txId          String
  userId        String
  eventType     String
  contractAddr  String?
  tokenSymbol   String?
  tokenAmount   String?
  fromAddr      String?
  toAddr        String?
  usdValue      Float?
  taxTreatment  String?
  metadata      String?
  createdAt     DateTime @default(now())

  transaction OnchainTransaction @relation(fields: [txId], references: [id])

  @@index([txId])
  @@index([userId])
  @@index([eventType])
  @@map("onchain_decoded_events")
}

// ── Jobs / background tasks ────────────────────────────────────────────────────

model JobQueue {
  id          String    @id @default(cuid())
  userId      String?
  jobType     String
  status      String    @default("PENDING")
  priority    Int       @default(0)
  payload     String
  result      String?
  errorMsg    String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([userId])
  @@index([jobType])
  @@map("job_queue")
}

// ── Chat interno ──────────────────────────────────────────────────────────────

model ChatConversation {
  id         String    @id @default(cuid())
  userId     String?
  sessionId  String    @unique
  status     String    @default("OPEN")
  guestName  String?
  guestEmail String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  messages   ChatMessage[]
  user       users?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  sender         String
  content        String
  createdAt      DateTime         @default(now())
  readAt         DateTime?
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

model ChatPushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("chat_push_subscriptions")
}

// ── Workspaces / B2B ──────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  ownerId     String
  plan        String   @default("FREE")
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  invites     WorkspaceInvite[]
  auditLogs   WorkspaceAuditLog[]

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("MEMBER")
  joinedAt    DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id           String    @id @default(cuid())
  workspaceId  String
  email        String
  role         String    @default("MEMBER")
  token        String    @unique
  status       String    @default("PENDING")
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())

  workspace    Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([email])
  @@map("workspace_invites")
}

model WorkspaceAuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String
  actorEmail  String?
  action      String
  metadata    String?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([actorId])
  @@map("workspace_audit_logs")
}

// ── Tax / Identity ─────────────────────────────────────────────────────────────

model TaxProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  documentType     String
  rut              String
  legalName        String
  businessActivity String?
  address          String
  commune          String
  city             String
  dteEmail         String
  isValidated      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tax_profiles")
}

model TaxDocument {
  id                      String   @id @default(cuid())
  userId                  String
  paymentId               String?
  subscriptionId          String?
  documentType            String
  status                  String   @default("DRAFT")
  folio                   String?
  externalTrackId         String?  @map("external_track_id")
  trackId                 String?  @map("track_id")
  submissionStatus        String?  @map("submission_status")
  issuerRut               String   @map("issuer_rut")
  issuerLegalName         String   @map("issuer_legal_name")
  issuerBusinessActivity  String   @map("issuer_business_activity")
  issuerAddress           String   @map("issuer_address")
  issuerCommune           String   @map("issuer_commune")
  issuerCity              String   @map("issuer_city")
  receiverRut             String   @map("receiver_rut")
  receiverLegalName       String   @map("receiver_legal_name")
  receiverBusinessActivity String? @map("receiver_business_activity")
  receiverAddress         String   @map("receiver_address")
  receiverCommune         String   @map("receiver_commune")
  receiverCity            String   @map("receiver_city")
  receiverDteEmail        String   @map("receiver_dte_email")
  netAmount               Int      @map("net_amount")
  exemptAmount            Int      @default(0) @map("exempt_amount")
  ivaAmount               Int      @map("iva_amount")
  totalAmount             Int      @map("total_amount")
  ivaRate                 Decimal  @default(0.19) @db.Decimal(6, 4) @map("iva_rate")
  lineItemsJson           String   @map("line_items_json")
  referenceJson           String?  @map("reference_json")
  xmlPayload              String?  @map("xml_payload")
  pdfUrl                  String?  @map("pdf_url")
  externalResponse        String?  @map("external_response")
  rejectionReason         String?  @map("rejection_reason")
  sentAt                  DateTime? @map("sent_at")
  acceptedAt              DateTime? @map("accepted_at")
  rejectedAt              DateTime? @map("rejected_at")
  voidedAt                DateTime? @map("voided_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([documentType])
  @@index([createdAt])
  @@map("tax_documents")
}

model SiiCredential {
  id                 String   @id @default(cuid())
  environment        String
  issuerRut          String   @map("issuer_rut")
  certificateName    String   @map("certificate_name")
  certificatePath    String?  @map("certificate_path")
  certificateExpires DateTime? @map("certificate_expires")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([issuerRut])
  @@index([environment])
  @@map("sii_credentials")
}

model SiiCaf {
  id           String   @id @default(cuid())
  documentType String   @map("document_type")
  folioStart   Int      @map("folio_start")
  folioEnd     Int      @map("folio_end")
  currentFolio Int      @map("current_folio")
  isActive     Boolean  @default(true)
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  @@index([documentType])
  @@index([isActive])
  @@map("sii_cafs")
}

// ── Billing / Coupons ──────────────────────────────────────────────────────────

model BillingCoupon {
  id                String    @id @default(cuid())
  code              String    @unique
  name              String
  description       String?
  type              String
  value             Decimal   @db.Decimal(18, 2)
  maxRedemptions    Int?
  currentRedemptions Int      @default(0)
  validFrom         DateTime
  validUntil        DateTime?
  applicablePlans   String
  status            String    @default("ACTIVE")
  createdAt         DateTime  @default(now())
  redemptions       BillingCouponRedemption[]

  @@index([status])
  @@index([code])
  @@map("billing_coupons")
}

model BillingCouponRedemption {
  id         String    @id @default(cuid())
  couponId   String
  userId     String?
  email      String?
  checkoutId String?
  redeemedAt DateTime  @default(now())

  coupon BillingCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@index([checkoutId])
  @@map("billing_coupon_redemptions")
}
